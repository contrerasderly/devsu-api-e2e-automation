{
  "name": "devsu-e2e-cypress-cucumber",
  "version": "1.0.0",
  "description": "E2E tests for Saucedemo using Cypress + Gherkin (Cucumber) + Allure",
  "scripts": {
    "cy:run": "cypress run --browser chrome --env allure=true",
    "cy:open": "cypress open",
    "cy:run:headless": "cypress run --headless --browser chrome --env allure=true",
    "allure:generate": "allure generate cypress/allure-results --clean -o cypress/allure-report",
    "allure:open": "allure open cypress/allure-report",
    "allure:serve": "allure serve cypress/allure-results"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^21.0.2",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.5",
    "@shelex/cypress-allure-plugin": "^2.40.2",
    "cypress": "^14.5.4"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/support/step_definitions/**/*.js"
    ]
  }
}
